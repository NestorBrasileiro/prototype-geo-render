{
  "name": "geo-mvt-api",
  "version": "1.0.0",
  "description": "API backend para geração de tiles vetoriais (MVT) a partir de dados geoespaciais armazenados no MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/scripts/seed.ts"
  },
  "keywords": [
    "geospatial",
    "mvt",
    "vector-tiles",
    "mongodb",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "geojson-vt": "^4.0.2",
    "mongodb": "^6.9.0",
    "vt-pbf": "^3.1.3"
  },
  "devDependencies": {
    "@mapbox/sphericalmercator": "^2.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geojson-vt": "^3.2.5",
    "@types/mapbox__sphericalmercator": "^1.2.3",
    "@types/node": "^22.5.0",
    "@types/vt-pbf": "^3.1.1",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
